    "showTerminalProgress": false
  },
  "warnings": {
    "anthropicExtraUsage": false
  },
  "compaction": {
    "enabled": false
  },
  "skillVisibility": {
    "hiddenSkills": [
      "grill-with-docs",
      "grilling",
      "improve-codebase-architecture",
      "teach"
    ]
