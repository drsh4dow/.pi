{
  "name": "pi-dotfiles",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "effect-tsgo patch",
    "typecheck": "tsc --noEmit",
    "check": "biome check agent/extensions",
    "check:fix": "biome check agent/extensions --write",
    "test:claude-auth": "bun test agent/extensions/claude-auth/test",
    "test:delegate": "node --test agent/extensions/delegate/test/*.test.ts",
    "test:web-access": "node --test agent/extensions/pi-web-access/test/*.test.ts",
    "verify": "bun run typecheck && bun run check && bun run test:claude-auth && bun run test:delegate && bun run test:web-access"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@effect/tsgo": "0.22.0",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  },
  "trustedDependencies": [
    "@google/genai",
    "protobufjs"
  ]
}
